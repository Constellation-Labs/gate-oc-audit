{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://constellationnetwork.io/schemas/openclaw-audit/audit-cron-rollup.schema.json",
  "title": "AuditCronRollup",
  "description": "Per-cron rollup produced by `openclaw audit report cron <job-id>`. One row per cron.executed event for the supplied jobId, paired with its matching agent.end and per-execution activity counters.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "jobId", "truncated", "rows", "manifest"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "jobId": { "type": "string" },
    "truncated": {
      "type": "boolean",
      "description": "True when the store holds more executions than fit in --last; the oldest were elided."
    },
    "rows": {
      "type": "array",
      "description": "Cron executions, newest first.",
      "items": {
        "type": "object",
        "required": [
          "jobId",
          "runId",
          "sessionId",
          "startedAt",
          "endedAt",
          "durationMs",
          "status",
          "error",
          "events"
        ],
        "additionalProperties": false,
        "properties": {
          "jobId": { "type": "string" },
          "runId": { "type": ["string", "null"] },
          "sessionId": { "type": ["string", "null"] },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the cron.executed event."
          },
          "endedAt": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "ISO 8601 timestamp of the matching agent.end, or null if none was found."
          },
          "durationMs": { "type": ["integer", "null"], "minimum": 0 },
          "status": {
            "enum": ["ok", "failed", "incomplete"],
            "description": "ok = paired agent.end with success=true; failed = paired agent.end with success=false; incomplete = no paired agent.end (still in flight or terminated abnormally)."
          },
          "error": { "type": ["string", "null"] },
          "events": {
            "type": "object",
            "description": "Counts of tool/llm/message events attributed to this run (sessionId + time window). Zero when status is incomplete.",
            "required": ["toolInvocations", "llmCalls", "messagesSent"],
            "additionalProperties": false,
            "properties": {
              "toolInvocations": { "type": "integer", "minimum": 0 },
              "llmCalls": { "type": "integer", "minimum": 0 },
              "messagesSent": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "manifest": {
      "description": "Matching `<jobId>.cron.*.json` manifest from the openclaw root, or null when none was found / no openclawDir was supplied.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["name", "schedule"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "schedule": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["kind", "at"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "at" },
                    "at": { "type": "string" }
                  }
                },
                {
                  "type": "object",
                  "required": ["kind", "everyMs"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "every" },
                    "everyMs": { "type": "integer", "minimum": 0 },
                    "anchorMs": { "type": "integer", "minimum": 0 }
                  }
                },
                {
                  "type": "object",
                  "required": ["kind", "expr"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "cron" },
                    "expr": { "type": "string" },
                    "tz": { "type": "string" },
                    "staggerMs": { "type": "integer", "minimum": 0 }
                  }
                },
                {
                  "type": "object",
                  "required": ["kind", "raw"],
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "unknown" },
                    "raw": { "type": "string" }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  }
}
